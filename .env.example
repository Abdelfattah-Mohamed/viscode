# ── Supabase (required for accounts, billing, and cloud data) ──
# 1. https://supabase.com/dashboard → New project
# 2. Project Settings → API: copy Project URL and anon public key
# 3. SQL Editor → run supabase/schema.sql (fresh) or supabase/MIGRATION-AUTH.sql (upgrade)
# 4. Auth → Providers → Email: enable, keep "Confirm email" ON
# 5. Auth → URL Configuration: set Site URL + add http://localhost:5173 redirect
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# ── Sign in with Google (optional) ──
# 1. https://console.cloud.google.com/apis/credentials → OAuth client ID (Web)
# 2. Authorized JavaScript origins: http://localhost:5173 and your production URL
# 3. Also enable the Google provider in Supabase Auth → Providers with this ID
#    (the app signs in via signInWithIdToken).
VITE_GOOGLE_CLIENT_ID=

# ── Launch telemetry (optional) ──
# Point at the bundled track-event Edge Function (stores events in the
# analytics_events table), or any endpoint that accepts JSON POSTs:
#   VITE_ANALYTICS_ENDPOINT=https://<project-ref>.supabase.co/functions/v1/track-event
VITE_ANALYTICS_ENDPOINT=
VITE_FEEDBACK_ENDPOINT=

# ── Admin access ──
# Admin is a database flag now (never a client env var). After signing up, run:
#   update public.profiles set is_admin = true where email = 'you@example.com';
